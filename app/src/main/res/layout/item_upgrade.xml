<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@drawable/bg_card"
    android:padding="12dp" android:layout_marginBottom="8dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvEmoji"
        android:layout_width="40dp" android:layout_height="40dp"
        android:textSize="26sp" android:gravity="center"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
        <TextView android:id="@+id/tvName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvDesc"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#BB99EE" android:textSize="11sp"/>
        <TextView android:id="@+id/tvLevel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#6CF5FF" android:textSize="11sp"/>
    </LinearLayout>
    <Button android:id="@+id/btnBuy"
        android:layout_width="wrap_content" android:layout_height="38dp"
        android:textSize="11sp" android:background="@drawable/btn_buy"
        android:textColor="#FFFFFF" android:paddingStart="10dp" android:paddingEnd="10dp"/>
</LinearLayout>
