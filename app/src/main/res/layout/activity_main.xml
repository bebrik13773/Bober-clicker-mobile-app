<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Счёт -->
    <TextView android:id="@+id/tvScore"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="0" android:textSize="42sp" android:textColor="#FFFFFF"
        android:textStyle="bold" android:gravity="center"
        android:fontFamily="sans-serif-condensed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"/>

    <!-- Сила тапа + реген -->
    <TextView android:id="@+id/tvPlus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="+1 / 🔋1/сек" android:textSize="13sp" android:textColor="#BB99EE"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp"/>

    <!-- Энергобар -->
    <ProgressBar android:id="@+id/progressEnergy"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp" android:layout_height="10dp"
        android:max="1000" android:progress="1000"
        android:progressTint="#6CF5FF"
        android:progressBackgroundTint="#2D1060"
        app:layout_constraintTop_toBottomOf="@id/tvPlus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"
        android:layout_marginStart="24dp" android:layout_marginEnd="24dp"/>

    <TextView android:id="@+id/tvEnergy"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="5000 / 5000" android:textSize="11sp" android:textColor="#7766AA"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/progressEnergy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp"/>

    <!-- Кнопка бобра (ImageButton) -->
    <ImageButton android:id="@+id/btnBober"
        android:layout_width="200dp" android:layout_height="200dp"
        android:background="@drawable/btn_bober_circle"
        android:scaleType="centerCrop"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEnergy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar"
        android:layout_marginBottom="12dp"/>

    <!-- Навбар -->
    <LinearLayout android:id="@+id/navBar"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:orientation="horizontal" android:background="#1A0840"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button android:id="@+id/btnShop"
            style="@style/NavBtn" android:text="🛒\nМагазин"/>
        <Button android:id="@+id/btnSkins"
            style="@style/NavBtn" android:text="🧥\nСкины"/>
        <Button android:id="@+id/btnAchievements"
            style="@style/NavBtn" android:text="🏆\nАчивки"/>
        <Button android:id="@+id/btnFly"
            style="@style/NavBtn" android:text="✈️\nFly Beaver"/>
    </LinearLayout>

    <!-- Панель магазина улучшений -->
    <FrameLayout android:id="@+id/panelShop"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:visibility="gone" android:background="#EE0D0628"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🛒 Улучшения"
                    android:textSize="20sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                <Button android:id="@+id/btnCloseShop" android:layout_width="48dp"
                    android:layout_height="48dp" android:text="✕"
                    android:textColor="#FFFFFF" android:background="@android:color/transparent" android:textSize="18sp"/>
            </LinearLayout>
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <LinearLayout android:id="@+id/listShop"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Панель скинов -->
    <FrameLayout android:id="@+id/panelSkins"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:visibility="gone" android:background="#EE0D0628"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🧥 Скины"
                    android:textSize="20sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                <Button android:id="@+id/btnCloseSkins" android:layout_width="48dp"
                    android:layout_height="48dp" android:text="✕"
                    android:textColor="#FFFFFF" android:background="@android:color/transparent" android:textSize="18sp"/>
            </LinearLayout>
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <LinearLayout android:id="@+id/listSkins"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Панель достижений -->
    <FrameLayout android:id="@+id/panelAchievements"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:visibility="gone" android:background="#EE0D0628"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar">
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🏆 Достижения"
                    android:textSize="20sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
                <Button android:id="@+id/btnCloseAchievements" android:layout_width="48dp"
                    android:layout_height="48dp" android:text="✕"
                    android:textColor="#FFFFFF" android:background="@android:color/transparent" android:textSize="18sp"/>
            </LinearLayout>
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <LinearLayout android:id="@+id/listAchievements"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Тост достижения -->
    <TextView android:id="@+id/tvToast"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="@drawable/bg_toast" android:textColor="#FFFFFF"
        android:textSize="15sp" android:padding="12dp" android:visibility="gone" android:alpha="0"
        app:layout_constraintBottom_toTopOf="@id/navBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
