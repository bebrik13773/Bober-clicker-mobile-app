<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0c1a2e">

    <FrameLayout android:id="@+id/gameContainer"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

    <!-- Стартовый экран -->
    <LinearLayout android:id="@+id/panelStart"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="vertical"
        android:gravity="center" android:padding="24dp"
        android:background="@drawable/bg_card">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✈️ Flying Beaver" android:textColor="#FFFFFF"
            android:textSize="28sp" android:textStyle="bold" android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Тапай чтобы лететь!\nУворачивайся от столбов"
            android:textColor="#88AABB" android:textSize="15sp" android:gravity="center"
            android:layout_marginTop="8dp"/>
        <Button android:id="@+id/btnStart"
            android:layout_width="160dp" android:layout_height="48dp"
            android:text="Играть!" android:layout_marginTop="16dp"
            android:background="@drawable/btn_buy" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnBack"
            android:layout_width="160dp" android:layout_height="40dp"
            android:text="← Назад" android:layout_marginTop="8dp"
            android:background="@android:color/transparent" android:textColor="#88AABB"/>
    </LinearLayout>

    <!-- Game Over -->
    <LinearLayout android:id="@+id/panelGameOver"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="vertical"
        android:gravity="center" android:padding="24dp"
        android:background="@drawable/bg_card" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💥 Конец!" android:textColor="#FF4444"
            android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvGameOverScore"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="18sp"
            android:gravity="center" android:layout_marginTop="8dp"/>
        <Button android:id="@+id/btnRestart"
            android:layout_width="160dp" android:layout_height="48dp"
            android:text="Ещё раз!" android:layout_marginTop="16dp"
            android:background="@drawable/btn_buy" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btnBackGameOver"
            android:layout_width="160dp" android:layout_height="40dp"
            android:text="← В игру" android:layout_marginTop="8dp"
            android:background="@android:color/transparent" android:textColor="#88AABB"/>
    </LinearLayout>

</FrameLayout>
